@stage.command("list")
@click.option("--as", "profile", default=None, help="List files staged under a named profile.", shell_complete=_complete_profiles)
def stage_list(profile):
    """Show currently staged files."""
    r = find_repo()
    if profile:
        staged = r / STAGED_DIR / profile
    else:
        staged = r / STAGED_DIR
    if not staged.is_dir():
        click.echo("No staged files.")
        return
    found = False
    for p in sorted(staged.rglob("*")):
        if p.is_file() and p.name != ".gitkeep":
