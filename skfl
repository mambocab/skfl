"""skfl - manage skills for agentic LLM products, skillfully."""

import hashlib
import os
import shutil
import subprocess
import sys
import tempfile
import tomllib
from pathlib import Path

import click
import tomli_w

SOURCES_DIR = "10_sources"
VETTED_DIR = "20_vetted"
PATCHES_DIR = "30_patches"
PACKAGES_DIR = "40_packages"
STAGED_DIR = "50_staged"

SKFL_TOML = "skfl.toml"

REPO_DIRS = [SOURCES_DIR, VETTED_DIR, PATCHES_DIR, PACKAGES_DIR, STAGED_DIR]

# Set by the -C global option; used by find_repo() when no explicit start is given.
_C_DIR: Path | None = None


# ── helpers ────────────────────────────────────────────────────────────

def find_repo(start: Path | None = None) -> Path:
    """Walk up from start (default: cwd) to find a directory containing skfl.toml.

    Falls back to the $SKFL_REPO environment variable when cwd is not inside
    any skfl repository, so commands and completions work from any directory.
    """
    p = (start or _C_DIR or Path.cwd()).resolve()
    while True:
        if (p / SKFL_TOML).is_file():
            return p
        parent = p.parent
        if parent == p:
            break
        p = parent
    if env_repo := os.environ.get("SKFL_REPO"):
        candidate = Path(env_repo).expanduser().resolve()
        if (candidate / SKFL_TOML).is_file():
            return candidate
    default_repo = Path.home() / ".skfl"
    if (default_repo / SKFL_TOML).is_file():
        return default_repo
    raise click.ClickException(
        "Not inside an skfl repository (no skfl.toml found). "
        "Run 'skfl init ~/.skfl' to create one, or set $SKFL_REPO."
    )


def _repo_name(repo: Path) -> str:
    """Short display name for a repo path, relative to home if possible."""
    try:
        return str(repo.relative_to(Path.home()))
    except ValueError:
        return str(repo)


def find_all_repos() -> list[tuple[str, Path]]:
    """Discover all standard skfl repositories as (name, path) pairs.

    Searches, in order:
      • ~/.skfl
      • ~/.local/.skfl
      • ~/*.skfl  (any *.skfl directory directly under the home directory)

    Results are deduplicated by resolved path and ordered as discovered.
    Only directories that contain a valid skfl.toml are included.
    """
    home = Path.home()
    candidates: list[Path] = [
        home / ".skfl",
        home / ".local" / ".skfl",
    ]
    for p in sorted(home.glob("*.skfl")):
        candidates.append(p)

    seen: set[Path] = set()
    result: list[tuple[str, Path]] = []
    for p in candidates:
        if not p.is_dir() or not (p / SKFL_TOML).is_file():
            continue
        resolved = p.resolve()
        if resolved in seen:
            continue
        seen.add(resolved)
        result.append((_repo_name(p), p))
    return result



def load_config(repo: Path) -> dict:
    with open(repo / SKFL_TOML, "rb") as f:
        return tomllib.load(f)


def save_config(repo: Path, config: dict) -> None:
    with open(repo / SKFL_TOML, "wb") as f:
        tomli_w.dump(config, f)


def resolve_to_source_rel(repo: Path, fpath: str | Path) -> Path:
    """Resolve a user-provided file path to a source-relative path."""
    sources = repo / SOURCES_DIR
    fpath = Path(fpath)
    if fpath.is_absolute():
        return fpath.relative_to(sources.resolve())
    candidate = sources / fpath
    if candidate.exists():
        return fpath
    return fpath.resolve().relative_to(sources.resolve())


def file_hash(path: Path) -> str:
    h = hashlib.sha256()
    with open(path, "rb") as f:
        for chunk in iter(lambda: f.read(8192), b""):
            h.update(chunk)
    return h.hexdigest()


def patches_dir_for(repo: Path, rel: Path) -> Path:
    """Return the default patches .d directory for a given source-relative path."""
    return Path(str(repo / PATCHES_DIR / rel) + ".d")


def list_patches_for(repo: Path, rel: Path) -> list[Path]:
    """List patches for a source file (files in its .d directory, sorted)."""
    patches = []
    d = patches_dir_for(repo, rel)
    if d.is_dir():
        patches.extend(sorted(p for p in d.iterdir() if p.suffix == ".patch"))
    return patches


def apply_patches(source_content: bytes, patches: list[Path]) -> bytes:
    """Apply a sequence of patch files to source content, returning the patched result."""
    result = source_content
    for patch_path in patches:
        with tempfile.NamedTemporaryFile(suffix=".orig", delete=False) as tmp:
            tmp.write(result)
            tmp_name = tmp.name
        try:
            proc = subprocess.run(
                ["patch", "--quiet", "--no-backup-if-mismatch", "-o", "-", tmp_name],
                input=patch_path.read_bytes(),
                capture_output=True,
            )
            if proc.returncode != 0:
                raise click.ClickException(
                    f"Patch {patch_path.name} failed to apply:\n{proc.stderr.decode()}"
                )
            result = proc.stdout
        finally:
            os.unlink(tmp_name)
    return result


def read_vetted_hash(repo: Path, rel: Path) -> str | None:
    """Read the stored vetted hash for a source file, or None if unvetted."""
    vetted_path = repo / VETTED_DIR / rel
    if not vetted_path.is_file():
        return None
    return vetted_path.read_text().strip()


def write_vetted_hash(repo: Path, rel: Path, hash_str: str) -> None:
    """Write a vetted hash file for a source file."""
    vetted_path = repo / VETTED_DIR / rel
    vetted_path.parent.mkdir(parents=True, exist_ok=True)
    vetted_path.write_text(hash_str + "\n")


def vet_status_for_file(repo: Path, rel: Path) -> str:
    """Return vetting status: 'vetted', 'modified', or 'unvetted'."""
    source_path = repo / SOURCES_DIR / rel
    if not source_path.is_file():
        return "missing"
    stored_hash = read_vetted_hash(repo, rel)
    if stored_hash is None:
        return "unvetted"
    if file_hash(source_path) == stored_hash:
        return "vetted"
    return "modified"


def all_source_files(repo: Path) -> list[Path]:
    """Return all files in the sources directory as relative paths."""
    sources = repo / SOURCES_DIR
    if not sources.is_dir():
        return []
    result = []
    for p in sorted(sources.rglob("*")):
        if p.is_file() and p.name != ".gitkeep":
            result.append(p.relative_to(sources))
    return result


def _stage_single_file(
    source_abs: Path,
    staged_path: Path,
    patch_paths: list[Path],
) -> int:
    """Read source, apply patches, write to staged location. Returns patch count."""
    content = source_abs.read_bytes()
    if patch_paths:
        content = apply_patches(content, patch_paths)
    staged_path.parent.mkdir(parents=True, exist_ok=True)
    staged_path.write_bytes(content)
    if os.access(source_abs, os.X_OK):
        staged_path.chmod(staged_path.stat().st_mode | 0o111)
    return len(patch_paths)


def all_patch_files(repo: Path) -> list[Path]:
    """Return all patch files under 30_patches/ sorted by path."""
    patches_root = repo / PATCHES_DIR
    if not patches_root.is_dir():
        return []
    return sorted(patches_root.rglob("*.patch"))


def read_package_manifest(repo: Path, name: str) -> list[dict]:
    """Read 40_packages/<name>/package.toml and return list of file entries."""
    manifest_path = repo / PACKAGES_DIR / name / "package.toml"
    if not manifest_path.is_file():
        raise click.ClickException(f"Package '{name}' not found.")
    with open(manifest_path, "rb") as f:
        data = tomllib.load(f)
    return data.get("file", [])


def write_package_manifest(repo: Path, name: str, entries: list[dict]) -> None:
    """Write file entries to 40_packages/<name>/package.toml."""
    manifest_path = repo / PACKAGES_DIR / name / "package.toml"
    data = {"file": [dict(e) for e in entries]}
    # Remove empty patch lists before writing (patches key is optional)
    for entry in data["file"]:
        if not entry.get("patches"):
            entry.pop("patches", None)
    manifest_path.write_bytes(tomli_w.dumps(data).encode())


def expand_paths(repo: Path, fpaths: list[str]) -> list[str]:
    """Expand any directory arguments into their constituent source files."""
    sources = repo / SOURCES_DIR
    result = []
    for fpath in fpaths:
        try:
            rel = resolve_to_source_rel(repo, fpath)
        except ValueError:
            result.append(fpath)  # let downstream handle the error
            continue
        source_path = sources / rel
        if source_path.is_dir():
            for p in sorted(source_path.rglob("*")):
                if p.is_file() and p.name != ".gitkeep":
                    result.append(str(p.relative_to(sources)))
        else:
            result.append(fpath)
    return result


def do_build_package(repo: Path, name: str) -> None:
    """Build a package: read manifest, vet sources, apply patches, stage."""
    entries = read_package_manifest(repo, name)
    if not entries:
        raise click.ClickException(f"Package '{name}' has no files.")

    sources = repo / SOURCES_DIR

    for entry in entries:
        rel = Path(entry["source"])
        dest_rel = Path(entry["dest"])
        patch_strs = entry.get("patches", [])

        source_abs = sources / rel
        if not source_abs.is_file():
            raise click.ClickException(f"Source not found: {rel}")

        # Validate patch files exist before touching disk
        patch_paths = []
        for p in patch_strs:
            patch_path = repo / p
            if not patch_path.is_file():
                raise click.ClickException(f"Patch not found: {p}")
            patch_paths.append(patch_path)

        # Vet check — drop into interactive flow
        status = vet_status_for_file(repo, rel)
        if status in ("unvetted", "modified"):
            if not vet_single_file(repo, rel):
                raise click.ClickException(
                    f"Cannot build package: {rel} was not vetted."
                )

        staged_path = repo / STAGED_DIR / name / dest_rel
        n = _stage_single_file(source_abs, staged_path, patch_paths)
        patch_note = f" ({n} patch{'es' if n != 1 else ''} applied)" if n else ""
        click.echo(f"  staged: {dest_rel}{patch_note}")

    click.echo(f"Built package '{name}': {len(entries)} file(s) staged to {STAGED_DIR}/{name}/.")


def vet_single_file(repo: Path, rel: Path) -> bool:
    """Interactively vet a single source file.

    Returns True if the file is (or becomes) vetted, False if skipped.
    """
    sources = repo / SOURCES_DIR
    source_path = sources / rel

    if not source_path.is_file():
        raise click.ClickException(f"Source file not found: {source_path}")

    status = vet_status_for_file(repo, rel)

    if status == "vetted":
        click.echo(f"  {rel}: already vetted (unchanged)")
        return True

    pager_cmd = ["less"]
    if str(rel).endswith(".md") and shutil.which("glow"):
        pager_cmd = ["glow", "-p"]

    if status == "modified":
        click.echo(f"  {rel}: source has changed since last vet. Opening in pager for review...")
        if sys.stdin.isatty():
            subprocess.run([*pager_cmd, str(source_path)])
        if not click.confirm(f"  Approve changes to {rel}?"):
            click.echo(f"  Skipping {rel}.")
            return False
    else:
        click.echo(f"  {rel}: unvetted. Opening in pager...")
        if sys.stdin.isatty():
            subprocess.run([*pager_cmd, str(source_path)])
        if not click.confirm(f"  Mark {rel} as vetted?"):
            click.echo(f"  Skipping {rel}.")
            return False

    write_vetted_hash(repo, rel, file_hash(source_path))
    click.echo(f"  {rel}: vetted.")
    return True


def do_vet_files(repo: Path, files: list[str]) -> None:
    """Vet the given source files."""
    files = expand_paths(repo, files)
    sources = repo / SOURCES_DIR
    for fpath in files:
        try:
            rel = resolve_to_source_rel(repo, fpath)
        except ValueError:
            raise click.ClickException(
                f"File {fpath} is not inside the sources directory ({sources})."
            )
        vet_single_file(repo, rel)


def _c_dir_from_ctx(ctx) -> Path | None:
    """Extract the -C directory from the root Click context, if present.

    During shell completion Click uses resilient_parsing=True and does not
    invoke the cli() callback, so the _C_DIR global is never set.  Reading
    the value directly from the context params lets completion callbacks
    honour -C without relying on the global.
    """
    if ctx is None:
        return None
    root = ctx
    while root.parent is not None:
        root = root.parent
    repo_dir = root.params.get("repo_dir")
    if repo_dir:
        return Path(repo_dir)
    return None


def _next_path_step(values: list[str], incomplete: str) -> list[str]:
    """Return the next unique path step(s) for directory-by-directory completion.

    Given a list of full paths and the current incomplete prefix, returns only
    the next path component.  When deeper levels exist the component is the
    directory name WITH a trailing slash — this prevents the shell from
    appending a space after a unique match, so the user can keep typing (or
    pressing Tab) to descend further.  When no deeper levels exist the full
    path is returned.
    """
    seen: set[str] = set()
    result: list[str] = []
    for value in values:
        if not value.startswith(incomplete):
            continue
        suffix = value[len(incomplete):]
        slash_idx = suffix.find("/")
        step = value if slash_idx == -1 else incomplete + suffix[:slash_idx] + "/"
        if step not in seen:
            seen.add(step)
            result.append(step)
    return result


def _complete_repo_dirs(ctx, param, incomplete):
    """Shell-completion callback: known skfl repository paths for -C.

    Returns the shortest usable path for each repo: a CWD-relative path when
    the repo lives under the current directory (e.g. '.skfl'), or an absolute
    path otherwise (e.g. '/home/user/.skfl').  Tilde paths are intentionally
    avoided: shells escape the '~' when inserting completions, producing
    '\\~/.skfl', which is not a valid path for -C.
    """
    from click.shell_completion import CompletionItem

    repos = find_all_repos()
    if not repos:
        return []

    cwd = Path.cwd()

    def best_path(p: Path) -> str:
        try:
            return str(p.relative_to(cwd))
        except ValueError:
            return str(p)

    return [
        CompletionItem(ps, help=name)
        for name, path in repos
        for ps in [best_path(path)]
        if not incomplete or ps.startswith(incomplete)
    ]


def _find_repo_for_completion(ctx=None) -> Path | None:
    """Return the repo root for a completion callback, or None if not in a repo."""
    try:
        return find_repo(start=_c_dir_from_ctx(ctx))
    except click.ClickException:
        return None


def _complete_source_files(ctx, param, incomplete):
    """Shell-completion callback: source files in the active repo.

    Completion proceeds directory-by-directory rather than listing all files.
    """
    from click.shell_completion import CompletionItem
    if (repo := _find_repo_for_completion(ctx)) is None:
        return []
    values = [str(rel) for rel in all_source_files(repo)]
    return [CompletionItem(v) for v in _next_path_step(values, incomplete)]


def _complete_patch_files(ctx, param, incomplete):
    """Shell-completion callback: patch files in the active repo.

    Completion proceeds directory-by-directory rather than listing all files.
    """
    from click.shell_completion import CompletionItem
    if (repo := _find_repo_for_completion(ctx)) is None:
        return []
    values = [str(p.relative_to(repo)) for p in all_patch_files(repo)]
    return [CompletionItem(v) for v in _next_path_step(values, incomplete)]


def _complete_packages(ctx, param, incomplete):
    """Shell-completion callback: package names from 40_packages/ subdirectories."""
    from click.shell_completion import CompletionItem
    if (repo := _find_repo_for_completion(ctx)) is None:
        return []
    packages_dir = repo / PACKAGES_DIR
    if not packages_dir.is_dir():
        return []
    return [
        CompletionItem(p.name)
        for p in sorted(packages_dir.iterdir())
        if p.is_dir() and (p / "package.toml").is_file() and p.name.startswith(incomplete)
    ]


# ── CLI ────────────────────────────────────────────────────────────────

@click.group()
@click.option(
    "-C",
    "repo_dir",
    default=None,
    metavar="PATH",
    help="Run as if skfl was started in PATH (like git -C).",
    type=click.Path(exists=True, file_okay=False),
    shell_complete=_complete_repo_dirs,
)
@click.pass_context
def cli(ctx, repo_dir):
    """skfl - manage skills for agentic LLM products, skillfully."""
    global _C_DIR
    _C_DIR = Path(repo_dir).resolve() if repo_dir else None


# ── init ───────────────────────────────────────────────────────────────

@cli.command()
@click.argument("path", default=".", type=click.Path())
def init(path):
    """Initialize a new skfl repository."""
    repo = Path(path).resolve()
    if (repo / SKFL_TOML).exists():
        raise click.ClickException(f"Repository already exists at {repo}")

    repo.mkdir(parents=True, exist_ok=True)
    for d in REPO_DIRS:
        (repo / d).mkdir(parents=True, exist_ok=True)
        (repo / d / ".gitkeep").touch()

    config = {
        "repository": {"version": 1},
        "sources": {},
    }
    save_config(repo, config)

    gitignore = repo / ".gitignore"
    if not gitignore.exists():
        gitignore.write_text("# skfl managed\n")

    click.echo(f"Initialized skfl repository at {repo}")


# ── doctor ─────────────────────────────────────────────────────────────

@cli.command()
def doctor():
    """Check the status of skfl's runtime dependencies."""
    tools = {
        "python3": ("Python interpreter", True),
        "git": ("Version control", True),
        "rsync": ("File synchronization (for 'skfl install rsync')", False),
        "stow": ("Symlink farm manager (for 'skfl install stow')", False),
        "glow": ("Markdown pager (for vetting)", False),
        "fzf": ("Interactive selection", False),
        "diff": ("Diff utility (for vetting and patching)", True),
        "patch": ("Patch utility (for patching)", True),
    }
    all_ok = True
    for tool, (desc, required) in tools.items():
        path = shutil.which(tool)
        if path:
            click.echo(f"  ok   {tool:10s} {desc} ({path})")
        elif required:
            click.echo(f"  MISS {tool:10s} {desc} [REQUIRED]")
            all_ok = False
        else:
            click.echo(f"  miss {tool:10s} {desc} [optional]")

    if all_ok:
        click.echo("\nAll required dependencies are available.")
    else:
        click.echo("\nSome required dependencies are missing.")
        sys.exit(1)


# ── source ─────────────────────────────────────────────────────────────

@cli.group()
def source():
    """Manage skill sources."""


@source.command("pull")
@click.argument("source_type_or_url", required=False, metavar="[github|URL]")
@click.argument("owner_repo", required=False, metavar="[OWNER/REPO]")
@click.option("--owner", help="GitHub owner")
@click.option("--repo", help="GitHub repo")
@click.option("--ref", help="Git ref (branch, tag, commit)")
def source_pull(source_type_or_url, owner_repo, owner, repo, ref):
    """Pull or update a source from GitHub.

    \b
    Examples:
      skfl source pull obra/superpowers
      skfl source pull github obra/superpowers
      skfl source pull https://github.com/obra/superpowers
      skfl source pull --owner obra --repo superpowers
    """
    r = find_repo()

    arg = source_type_or_url
    if arg:
        if arg == "github" and owner_repo:
            # skfl source pull github owner/repo
            if "/" not in owner_repo:
                raise click.ClickException(
                    f"Expected OWNER/REPO, got: {owner_repo!r}"
                )
            owner, repo = owner_repo.split("/", 1)
        elif "/" in arg and not arg.startswith("http"):
            # skfl source pull owner/repo
            if owner_repo:
                raise click.ClickException(
                    f"Unexpected argument {owner_repo!r}."
                )
            owner, repo = arg.split("/", 1)
        else:
            # Full URL form — owner_repo must be absent
            if owner_repo:
                raise click.ClickException(
                    f"Unexpected argument {owner_repo!r}. "
                    "Use: skfl source pull github OWNER/REPO"
                )
            url = arg.rstrip("/")
            if url.endswith(".git"):
                url = url[:-4]
            parts = url.split("/")
            try:
                gh_idx = parts.index("github.com")
                owner = parts[gh_idx + 1]
                repo = parts[gh_idx + 2]
            except (ValueError, IndexError):
                raise click.ClickException(f"Could not parse GitHub URL: {url}")

    if not owner or not repo:
        raise click.ClickException(
            "Specify a source: 'github OWNER/REPO', a GitHub URL, or --owner/--repo."
        )

    source_key = f"{owner}/{repo}"
    dest = r / SOURCES_DIR / "github" / owner / repo

    if dest.exists():
        click.echo(f"Updating source {source_key}...")
        cmd = ["git", "-C", str(dest), "fetch", "--depth=1", "origin"]
        if ref:
            cmd.append(ref)
        subprocess.run(cmd, check=True)
        checkout_ref = ref or "FETCH_HEAD"
        subprocess.run(
            ["git", "-C", str(dest), "checkout", checkout_ref, "--", "."],
            check=True,
        )
        click.echo(f"Updated {source_key}.")
    else:
        click.echo(f"Pulling source {source_key}...")
        dest.parent.mkdir(parents=True, exist_ok=True)
        cmd = ["git", "clone", "--depth=1"]
        if ref:
            cmd += ["--branch", ref]
        cmd += [f"https://github.com/{owner}/{repo}.git", str(dest)]
        subprocess.run(cmd, check=True)
        click.echo(f"Pulled {source_key} to {dest}.")

    config = load_config(r)
    config.setdefault("sources", {})
    config["sources"][source_key] = {
        "type": "github",
        "owner": owner,
        "repo": repo,
        "ref": ref or "",
        "path": f"github/{owner}/{repo}",
    }
    save_config(r, config)


@source.command("custom")
@click.argument("name")
@click.argument("path", type=click.Path(exists=True))
def source_custom(name, path):
    """Register a directory of self-authored files as a source."""
    r = find_repo()
    dest = r / SOURCES_DIR / "custom" / name

    if dest.exists():
        raise click.ClickException(f"Custom source '{name}' already exists at {dest}")

    src = Path(path).resolve()
    dest.mkdir(parents=True, exist_ok=True)
    shutil.copytree(src, dest, dirs_exist_ok=True)

    config = load_config(r)
    config.setdefault("sources", {})
    config["sources"][name] = {
        "type": "custom",
        "name": name,
        "path": f"custom/{name}",
    }
    save_config(r, config)
    click.echo(f"Registered custom source '{name}' from {src}.")


@source.command("list")
def source_list():
    """List all registered sources."""
    r = find_repo()
    config = load_config(r)
    sources = config.get("sources", {})
    if not sources:
        click.echo("No sources registered.")
        return
    for name, info in sources.items():
        stype = info.get("type", "unknown")
        spath = info.get("path", "")
        click.echo(f"  {name:30s} type={stype:10s} path={spath}")


# ── vet ────────────────────────────────────────────────────────────────

@cli.command("vet")
@click.argument("files", nargs=-1, required=True, type=click.Path(), shell_complete=_complete_source_files)
def vet(files):
    """Vet source files by reviewing and approving their content."""
    r = find_repo()
    do_vet_files(r, list(files))


@cli.command("vet-status")
@click.argument("files", nargs=-1, type=click.Path(), shell_complete=_complete_source_files)
def vet_status(files):
    """Show vetting status of source files."""
    r = find_repo()
    if files:
        for fpath in expand_paths(r, list(files)):
            try:
                rel = resolve_to_source_rel(r, fpath)
            except ValueError:
                raise click.ClickException(f"File {fpath} is not inside sources.")
            status = vet_status_for_file(r, rel)
            click.echo(f"  {status:10s} {rel}")
        return

    found = False
    for rel in all_source_files(r):
        found = True
        status = vet_status_for_file(r, rel)
        click.echo(f"  {status:10s} {rel}")
    if not found:
        click.echo("No source files found.")


# ── patch ──────────────────────────────────────────────────────────────

@cli.group()
def patch():
    """Manage patches on top of source files."""


@patch.command("create")
@click.argument("source_file", type=click.Path(), shell_complete=_complete_source_files)
@click.option("--name", "-n", default=None, help="Short description for the patch filename.")
def patch_create(source_file, name):
    """Create a new patch for a vetted source file."""
    r = find_repo()
    sources = r / SOURCES_DIR

    try:
        rel = resolve_to_source_rel(r, source_file)
    except ValueError:
        raise click.ClickException(
            f"File {source_file} is not inside the sources directory."
        )

    src = sources / rel
    if not src.is_file():
        raise click.ClickException(f"Source file not found: {src}")

    if vet_status_for_file(r, rel) != "vetted":
        if not vet_single_file(r, rel):
            return

    pdir = patches_dir_for(r, rel)
    existing = list_patches_for(r, rel)
    next_num = len(existing) + 1

    if not name:
        name = click.prompt("Patch name")
    safe_name = name.replace(" ", "-").replace("/", "-")
    patch_name = f"{next_num:03d}-{safe_name}.patch"

    base_content = src.read_bytes()
    if existing:
        base_content = apply_patches(base_content, existing)

    suffix = src.suffix or ".txt"
    with tempfile.NamedTemporaryFile(
        mode="wb", suffix=suffix, delete=False, prefix="skfl-edit-"
    ) as tmp:
        tmp.write(base_content)
        tmp_path = tmp.name

    editor = os.environ.get("EDITOR", "vi")
    click.echo(f"Opening {rel} in {editor} for editing...")
    subprocess.run([editor, tmp_path])

    edited_content = Path(tmp_path).read_bytes()
    os.unlink(tmp_path)

    if edited_content == base_content:
        click.echo("No changes made. Patch not created.")
        return

    with tempfile.NamedTemporaryFile(mode="wb", suffix=".orig", delete=False) as orig_tmp:
        orig_tmp.write(base_content)
        orig_path = orig_tmp.name
    with tempfile.NamedTemporaryFile(mode="wb", suffix=".new", delete=False) as new_tmp:
        new_tmp.write(edited_content)
        new_path = new_tmp.name

    proc = subprocess.run(
        ["diff", "-u", orig_path, new_path],
        capture_output=True,
    )
    os.unlink(orig_path)
    os.unlink(new_path)

    patch_content = proc.stdout
    pdir.mkdir(parents=True, exist_ok=True)
    patch_path = pdir / patch_name
    patch_path.write_bytes(patch_content)

    click.echo(f"Created patch: {patch_path.relative_to(r)}")


@patch.command("list")
@click.argument("source_file", required=False, type=click.Path(), shell_complete=_complete_source_files)
def patch_list(source_file):
    """List patches, optionally for a specific source file."""
    r = find_repo()

    if source_file:
        try:
            rel = resolve_to_source_rel(r, source_file)
        except ValueError:
            rel = Path(source_file)
        patches = list_patches_for(r, rel)
        if not patches:
            click.echo(f"No patches for {rel}.")
            return
        click.echo(f"Patches for {rel}:")
        for p in patches:
            click.echo(f"  {p.name}")
    else:
        found = False
        for p in all_patch_files(r):
            found = True
            click.echo(f"  {p.relative_to(r)}")
        if not found:
            click.echo("No patches.")


@patch.command("remove")
@click.argument("patch_file", type=click.Path(), shell_complete=_complete_patch_files)
def patch_remove(patch_file):
    """Remove a patch."""
    r = find_repo()
    patch_path = Path(patch_file)

    if not patch_path.is_absolute():
        candidate = r / patch_path
        if candidate.is_file():
            patch_path = candidate
        else:
            candidate = r / PATCHES_DIR / patch_path
            if candidate.is_file():
                patch_path = candidate
            else:
                raise click.ClickException(f"Patch file not found: {patch_file}")

    if not patch_path.is_file():
        raise click.ClickException(f"Patch file not found: {patch_path}")

    patch_path.unlink()
    click.echo(f"Removed patch: {patch_file}")

    parent = patch_path.parent
    if parent.is_dir() and not any(parent.iterdir()):
        parent.rmdir()


