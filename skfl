@cli.group()
def package():
    """Manage packages: named, installable subsets of vetted sources."""


@package.command("init")
@click.argument("name")
def package_new(name):
    """Create a new empty package."""
    r = find_repo()
    pkg_dir = r / PACKAGES_DIR / name
    manifest_path = pkg_dir / "package.toml"
    if manifest_path.exists():
        raise click.ClickException(f"Package '{name}' already exists.")
    pkg_dir.mkdir(parents=True, exist_ok=True)
    write_package_manifest(r, name, [])
    click.echo(f"Created package '{name}' at {pkg_dir.relative_to(r)}.")


@package.command("list")
def package_list():
    """List all defined packages."""
    r = find_repo()
    pkgs_dir = r / PACKAGES_DIR
    if not pkgs_dir.is_dir():
        click.echo("No packages defined.")
        return
    packages = sorted(
        p.name for p in pkgs_dir.iterdir()
        if p.is_dir() and (p / "package.toml").is_file()
    )
    if not packages:
        click.echo("No packages defined.")
        return
    for name in packages:
        click.echo(f"  {name}")


@package.command("add")
@click.argument("name", shell_complete=_complete_packages)
@click.argument("source_path", type=click.Path(), shell_complete=_complete_source_files)
@click.argument("dest_path", type=click.Path())
@click.option("--with-patch", "patches", multiple=True, type=click.Path(),
              shell_complete=_complete_patch_files,
              help="Patch to apply to this file (may be repeated, applied in order).")
def package_add(name, source_path, dest_path, patches):
    """Add a source file to a package.

    SOURCE_PATH is relative to 10_sources/.
    DEST_PATH is where the file appears at install time.
    """
    r = find_repo()
    manifest_path = r / PACKAGES_DIR / name / "package.toml"
    if not manifest_path.is_file():
        raise click.ClickException(
            f"Package '{name}' not found. Run 'skfl package init {name}' first."
        )

    sources = r / SOURCES_DIR
    try:
        rel = resolve_to_source_rel(r, source_path)
    except ValueError:
        raise click.ClickException(
            f"Source path '{source_path}' is not inside the sources directory."
        )

    source_abs = sources / rel
    if not source_abs.is_file():
        raise click.ClickException(f"Source not found: {source_abs}")

    for p in patches:
        patch_path = r / p if not Path(p).is_absolute() else Path(p)
        if not patch_path.is_file():
            raise click.ClickException(f"Patch file not found: {p}")

    entries = read_package_manifest(r, name)
    if any(e["dest"] == dest_path for e in entries):
        raise click.ClickException(
            f"Destination '{dest_path}' already exists in package '{name}'."
        )

    entry: dict = {"source": str(rel), "dest": dest_path}
    if patches:
        entry["patches"] = list(patches)
    entries.append(entry)
    write_package_manifest(r, name, entries)
    click.echo(f"  added: {dest_path} <- {rel}")


@package.command("show")
@click.argument("name", shell_complete=_complete_packages)
def package_show(name):
    """Show files in a package as a tree."""
    r = find_repo()
    entries = read_package_manifest(r, name)
    if not entries:
        click.echo(f"Package '{name}' has no files.")
        return

    tree: dict = {}
    for entry in entries:
        dest_rel = Path(entry["dest"])
        node = tree
        for part in dest_rel.parts[:-1]:
            node = node.setdefault(part, {})
        node[dest_rel.parts[-1]] = None

    def render(node: dict, prefix: str = "") -> None:
        entries_list = sorted(node.keys(), key=lambda k: (node[k] is not None, k))
        for i, key in enumerate(entries_list):
            connector = "└── " if i == len(entries_list) - 1 else "├── "
            child = node[key]
            click.echo(prefix + connector + key)
            if child is not None:
                extension = "    " if i == len(entries_list) - 1 else "│   "
                render(child, prefix + extension)

    click.echo(name)
    render(tree)


@package.command("build")
@click.argument("name", shell_complete=_complete_packages)
def package_build(name):
    """Build a package: vet-check, apply patches, stage to 50_staged/<name>/."""
    r = find_repo()
    do_build_package(r, name)


def _resolve_install_paths(repo: Path, name: str, tool: str, target: str) -> tuple[Path, Path]:
    """Build (if needed), validate tool, resolve target; return (staged_dir, target_path)."""
    staged = repo / STAGED_DIR / name
    if not staged.is_dir():
        do_build_package(repo, name)
    if not shutil.which(tool):
        raise click.ClickException(f"{tool} is not installed. Install it and try again.")
    target_path = Path(target).resolve()
    target_path.mkdir(parents=True, exist_ok=True)
    return staged, target_path


@package.group()
def install():
    """Install a built package to a target directory."""


@install.command("rsync")
@click.argument("name", shell_complete=_complete_packages)
@click.argument("target", type=click.Path())
def package_install_rsync(name, target):
    """Install a package using rsync."""
    r = find_repo()
    staged, target_path = _resolve_install_paths(r, name, "rsync", target)
    subprocess.run(
        ["rsync", "-av", "--exclude=.gitkeep", str(staged) + "/", str(target_path)],
        check=True,
    )
    click.echo(f"Installed package '{name}' to {target_path}.")


@install.command("stow")
@click.argument("name", shell_complete=_complete_packages)
@click.argument("target", type=click.Path())
def package_install_stow(name, target):
    """Install a package using GNU Stow."""
    r = find_repo()
    staged, target_path = _resolve_install_paths(r, name, "stow", target)
    subprocess.run(
        ["stow", "--dir", str(r / STAGED_DIR), "--target", str(target_path), name],
        check=True,
    )
    click.echo(f"Installed package '{name}' to {target_path} via stow.")


# ── completion ─────────────────────────────────────────────────────────


def _patch_zsh_completion_source(source: str) -> str:
    """Patch Click's zsh completion script to suppress trailing space for directory steps.

    Click's generated script uses ``compadd -U -V unsorted -a completions`` for all
    plain completion items, which appends a space after each one.  For items ending
    with '/' (directory steps in dir-by-dir path completion) the space is wrong —
    it prevents the user from pressing Tab again to descend further.

    The patch replaces the single compadd call with two: one with ``-S ''`` (no
    suffix) for directory steps, and one with the default space suffix for leaf files.
    """
    old = "    if [ -n \"$completions\" ]; then\n        compadd -U -V unsorted -a completions\n    fi"
    new = (
        "    if [ -n \"$completions\" ]; then\n"
        "        local -a _skfl_dirs _skfl_files\n"
        "        for _skfl_c in \"${completions[@]}\"; do\n"
        "            if [[ \"$_skfl_c\" == */ ]]; then _skfl_dirs+=(\"$_skfl_c\")\n"
        "            else _skfl_files+=(\"$_skfl_c\"); fi\n"
        "        done\n"
        "        (( ${#_skfl_dirs} )) && compadd -S '' -U -V unsorted -a _skfl_dirs\n"
        "        (( ${#_skfl_files} )) && compadd -U -V unsorted -a _skfl_files\n"
        "    fi"
    )
    return source.replace(old, new)


@cli.command("completion")
@click.argument("shell", type=click.Choice(["bash", "zsh", "fish"]))
def completion(shell):
    """Output the shell completion script for SHELL.

    Generate the script once and save it to a file — do not eval on every
    shell startup, as that re-invokes skfl (and uv) each time.

    \b
    bash — add to ~/.bashrc:
      skfl completion bash > ~/.local/share/bash-completion/completions/skfl

    \b
    zsh — add directory to fpath before compinit, then run once:
      skfl completion zsh > ~/.zfunc/_skfl
      # ~/.zshrc: fpath=(~/.zfunc $fpath); autoload -Uz compinit && compinit

    \b
    fish — auto-loaded after running once:
      skfl completion fish > ~/.config/fish/completions/skfl.fish

    \b
    For completions to work from any directory, skfl automatically falls back
    to ~/.skfl if it exists.  To use a different location, set $SKFL_REPO:
      export SKFL_REPO=~/path/to/your/skfl-repo
    """
    from click.shell_completion import BashComplete, ZshComplete, FishComplete

    cls = {"bash": BashComplete, "zsh": ZshComplete, "fish": FishComplete}[shell]
    source = cls(cli, {}, "skfl", "_SKFL_COMPLETE").source()
    if shell == "zsh":
        source = _patch_zsh_completion_source(source)
    click.echo(source, nl=False)


