FROM fedora:41

RUN dnf install -y \
    python3 \
    python3-pip \
    diffutils \
    patch \
    rsync \
    stow \
    git \
    bash \
    coreutils \
    findutils \
    sed \
    && dnf clean all

RUN pip install --no-cache-dir \
    click \
    tomli-w \
    pytest

# Install bats-core from source for a consistent, recent version.
RUN git clone --depth 1 https://github.com/bats-core/bats-core.git /tmp/bats-core \
    && /tmp/bats-core/install.sh /usr/local \
    && rm -rf /tmp/bats-core

ENV PYTHONDONTWRITEBYTECODE=1

WORKDIR /src
