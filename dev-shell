#!/usr/bin/env bash
# dev-shell — drop into an isolated shell for interactive skfl testing.
#
# Creates a temp directory with .local/bin containing symlinks to host
# executables, copies skfl into .local/bin, initialises a fresh skfl
# repo, and execs an interactive shell with PATH restricted to .local/bin.
#
# Cleans up the temp directory on exit.

set -euo pipefail

EXTRA_CMDS=()
while [ $# -gt 0 ]; do
    case "$1" in
        --with) EXTRA_CMDS+=("$2"); shift 2 ;;
        --with=*) EXTRA_CMDS+=("${1#--with=}"); shift ;;
        *) echo "usage: dev-shell [--with CMD]..." >&2; exit 1 ;;
    esac
done

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
WORK="$(mktemp -d)"

# Preserve the real uv Python cache so uv doesn't re-download/re-patch
# Python into the temp HOME directory on every run.
UV_PYTHON_INSTALL_DIR="${UV_PYTHON_INSTALL_DIR:-$HOME/.local/share/uv/python}"
export UV_PYTHON_INSTALL_DIR

cleanup() {
    rm -rf "$WORK"
}
trap cleanup EXIT

# ── .local/bin — symlinks to host executables ─────────────────────────

BIN="$WORK/.local/bin"
mkdir -p "$BIN"

for cmd in uv python3 git diff patch less env sh \
           cat cp mv mkdir rm chmod ls wc head tail sort find sed \
           rsync stow glow fzf "${EXTRA_CMDS[@]}"; do
    p="$(command -v "$cmd" 2>/dev/null || true)"
    if [ -n "$p" ]; then
        ln -s "$p" "$BIN/$cmd"
    else
        echo "warning: $cmd not found" >&2
    fi
done

# skfl: copy the source and create a thin wrapper that invokes it via `uv run`.
command -v uv >/dev/null 2>&1 || { echo "error: uv is required but not found" >&2; exit 1; }
cp "$SCRIPT_DIR/skfl" "$WORK/.local/skfl.py"
cat > "$BIN/skfl" <<'WRAPPER'
#!/bin/sh
exec uv run --script "${0%/*}/../skfl.py" "$@"
WRAPPER
chmod +x "$BIN/skfl"

# ── initialise a test repo ────────────────────────────────────────────

cd "$WORK"
PATH="$BIN" HOME="$WORK" "$BIN/skfl" init "$WORK/.skfl"

# ── shell completion ──────────────────────────────────────────────────

SHELL="${SHELL:-sh}"
case "$SHELL" in
    */zsh)
        mkdir -p "$WORK/.zfunc"
        PATH="$BIN" HOME="$WORK" "$BIN/skfl" completion zsh > "$WORK/.zfunc/_skfl"
        cat > "$WORK/.zshrc" <<ZSHRC
fpath=($WORK/.zfunc \$fpath)
autoload -Uz compinit && compinit
PS1='(skfl-dev) \$ '
ZSHRC
        ;;
    */bash)
        PATH="$BIN" HOME="$WORK" "$BIN/skfl" completion bash > "$WORK/.bash_completion"
        cat > "$WORK/.bashrc" <<BASHRC
source "$WORK/.bash_completion"
PS1='(skfl-dev) \$ '
BASHRC
        ;;
esac

# ── drop into interactive shell ───────────────────────────────────────

cat <<EOF

  skfl dev shell
  repo:  $WORK/.skfl
  path:  .local/bin
  exit:  type 'exit'

EOF

case "$SHELL" in
    */zsh)  ZDOTDIR="$WORK" PATH="$BIN" HOME="$WORK" exec "$SHELL" --no-globalrcs ;;
    */bash) PATH="$BIN" HOME="$WORK" exec "$SHELL" --init-file "$WORK/.bashrc" ;;
    *)      PATH="$BIN" HOME="$WORK" PS1='(skfl-dev) $ ' exec "$SHELL" --norc --noprofile ;;
esac
